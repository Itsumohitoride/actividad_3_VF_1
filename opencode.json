{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "leader",
  "instructions": ["AGENTS.md"],
  "agent": {
    "leader": {
      "description": "Orquestador principal. Descompone trabajo, lanza implementer, coordina features.",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "edit": "deny",
        "bash": { "git *": "allow", "kubectl *": "allow", "docker *": "allow", "helm *": "allow", "python *": "allow", "*": "ask" },
        "task": "allow"
      }
    },
    "implementer": {
      "description": "Escribe codigo, crea/edita archivos. Sigue instrucciones del leader.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "edit": "allow",
        "bash": { "git *": "allow", "kubectl *": "allow", "docker *": "allow", "helm *": "allow", "python *": "allow", "*": "ask" }
      }
    }
  }
}
